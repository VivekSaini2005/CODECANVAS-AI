generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  rating    Int      @default(0)
  streak    Int      @default(0)
  createdAt DateTime @default(now())

  submissions Submission[]
  progress    Progress[]
  posts       Post[]

  @@map("users")
}

model Problem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  difficulty  Difficulty
  tags        String[]
  starterCode String?
  createdAt   DateTime @default(now())

  submissions   Submission[]
  progress      Progress[]
  sheetProblems SheetProblem[]

  @@map("problems")
}

model Submission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  problemId String   @db.Uuid
  language  String
  code      String
  status    String
  runtime   Float?
  memory    Float?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@map("submissions")
}

model Sheet {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())

  problems SheetProblem[]

  @@map("sheets")
}

model SheetProblem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sheetId   String @db.Uuid
  problemId String @db.Uuid
  order     Int

  sheet   Sheet   @relation(fields: [sheetId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@map("sheet_problems")
}

model Progress {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @db.Uuid
  problemId String @db.Uuid
  status    Status
  attempts  Int    @default(0)

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@map("progress")
}

model Post {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  problemId String?  @db.Uuid
  title     String
  content   String
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])

  @@map("comments")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Status {
  PENDING
  ATTEMPTED
  SOLVED
}